  <section class="jumbotron text-center">
    <div class="container">
      <h1 class="jumbotron-heading">Favorites</h1>
      <p class="lead text-muted">Welcome to your favorite cars collection. This description is short and sweet, feel free to skip over it entirely.</p>
    </div>
  </section>


<div class="album py-5 bg-light">
    <div class="container">  
      <div class="row">

        <% if (favorites.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">♡</div>
            <h3>No favorites yet</h3>
            <p>Browse cars and hit <strong>+ Favorite</strong> to save them here.</p>
            <a href="/" class="btn btn-outline-secondary mt-3">Explore Cars</a>
          </div>
        <% } else { %>
          <% favorites.forEach((f) =>{ %>
          <div class="col-md-4 card-col">
            <div class="card mb-4 box-shadow">
              <img class="card-img-top imgresp" src="<%= f.image %>" alt="<%= f.make %> <%= f.model %>">
              <div class="card-body">
                <p class="card-text"><%= f.make %> <%= f.model %></p>
                <div class="d-flex justify-content-center align-items-center">
                  <div class="btn-group">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#editModal<%= f.id %>">Edit</button>
                  </div>
                  <!--<small class="text-muted">Placeholder</small>-->
                </div>
              </div>
            </div>
          </div>

            <!-- Modal -->
            <div class="modal fade" id="editModal<%= f.id %>" tabindex="-1" role="dialog" aria-hidden="true">
              <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">

                  <div class="modal-header">
                    <h5 class="modal-title"><%= f.make %> <%= f.model %></h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                      <span aria-hidden="true">&times;</span>
                    </button>
                  </div>

                  <div class="modal-body">
                    <!-- Source tabs -->
                    <div class="img-source-tabs">
                      <button type="button" class="img-tab-btn active" data-tab="url-<%= f.id %>">Use URL</button>
                      <button type="button" class="img-tab-btn" data-tab="upload-<%= f.id %>">Upload File</button>
                    </div>

                    <!-- URL panel -->
                    <div id="url-<%= f.id %>" class="img-tab-pane">
                      <form id="url-form-<%= f.id %>" method="POST" action="/cars/favorites/edit/<%= f.id %>?_method=PUT">
                        <input type="hidden" name="favid" value="<%= f.id %>">
                        <input type="text" class="form-control" name="newimagelink" placeholder="https://…" autocomplete="off">
                      </form>
                    </div>

                    <!-- Upload panel -->
                    <div id="upload-<%= f.id %>" class="img-tab-pane" style="display:none;">
                      <form id="upload-form-<%= f.id %>" method="POST" action="/cars/favorites/edit/<%= f.id %>?_method=PUT" enctype="multipart/form-data">
                        <input type="hidden" name="favid" value="<%= f.id %>">
                        <input type="file" class="form-control-file" name="newimage" accept="image/*">
                      </form>
                    </div>
                  </div>

                  <div class="modal-footer" style="justify-content:space-between;">
                    <form method="POST" action="/cars/favorites/delete/<%= f.id %>?_method=DELETE" style="margin:0;">
                      <button type="submit" class="btn btn-sm btn-outline-secondary">Remove</button>
                    </form>
                    <button type="button" class="btn btn-primary fav-update-btn" data-id="<%= f.id %>">Update Image</button>
                  </div>

                </div>
              </div>
            </div>
          <% }) %>
        <% } %>

      </div>
      <%- include('partials/pagination') %>
    </div>
  </div>