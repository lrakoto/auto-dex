<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>AutoDex</title>
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= typeof ogTitle !== 'undefined' ? ogTitle : 'AutoDex' %>">
    <meta property="og:description" content="<%= typeof ogDescription !== 'undefined' ? ogDescription : 'Browse thousands of car makes and models.' %>">
    <% if (typeof ogImage !== 'undefined' && ogImage) { %>
      <meta property="og:image" content="<%= ogImage %>">
    <% } %>
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <div class="overlay">
    <main role="main">
      <%- include('partials/alerts') %>
      <header class="masthead">
        <div class="inner">
          <a href="/" class="masthead-brand">AutoDex</a>
          <nav class="nav nav-masthead" id="nav-masthead">
            <a class="nav-link" href="/">Home</a>
            <a class="nav-link" href="/makes">Browse Manufacturers</a>
            <% if (!currentUser) { %>
              <a class="nav-link" href="/auth/signup">Sign Up</a>
              <a class="nav-link" href="/auth/login">Log In</a>
            <% } else { %>
              <a class="nav-link" href="/cars/favorites">Favorites</a>
              <a class="nav-link" href="/garage">My Garage</a>
              <% if (currentUser.isAdmin) { %>
                <a class="nav-link" href="/garage/admin">Admin</a>
              <% } %>
              <a class="nav-link" href="/auth/logout">Log Out</a>
            <% } %>
          </nav>
          <div class="nav-right">
            <button id="nav-search-btn" class="nav-search-btn" aria-label="Search">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="6.5" cy="6.5" r="4.5"/>
                <line x1="10.5" y1="10.5" x2="14" y2="14"/>
              </svg>
            </button>
            <button id="nav-hamburger" class="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
              <span></span><span></span><span></span>
            </button>
          </div>
        </div>
      </header>

      <%- body %>

    </main>

    <footer class="mastfoot">
      <div class="inner">
        <p>&copy; <%= new Date().getFullYear() %> AutoDex &mdash; Created by <a href="http://threeohfivestudios.com/" target="_blank">305 Studios</a> &nbsp;&middot;&nbsp; <a href="https://github.com/lrakoto/auto-dex" target="_blank">GitHub</a></p>
      </div>
    </footer>

    <!-- Mobile nav menu -->
    <div id="nav-mobile-menu" class="nav-mobile-menu" aria-hidden="true">
      <a class="nav-link" href="/">Home</a>
      <a class="nav-link" href="/makes">Browse Manufacturers</a>
      <% if (!currentUser) { %>
        <a class="nav-link" href="/auth/signup">Sign Up</a>
        <a class="nav-link" href="/auth/login">Log In</a>
      <% } else { %>
        <a class="nav-link" href="/cars/favorites">Favorites</a>
        <a class="nav-link" href="/garage">My Garage</a>
        <% if (currentUser.isAdmin) { %>
          <a class="nav-link" href="/garage/admin">Admin</a>
        <% } %>
        <a class="nav-link" href="/auth/logout">Log Out</a>
      <% } %>
    </div>
    <!-- Nav search overlay: lives outside <main> to escape z-index stacking contexts -->
    <div id="nav-search-overlay" class="nav-search-overlay" aria-hidden="true">
      <div class="nav-search-inner">
        <div class="nav-search-input-wrap search-input-wrap">
          <input type="text" name="q" id="nav-search-input" class="nav-search-input" placeholder="Search makes and models…" autocomplete="off" aria-label="Search">
          <div class="suggest-dropdown"></div>
        </div>
        <button class="nav-search-close" aria-label="Close search">&times;</button>
      </div>
    </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.2.1.slim.min.js" integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js" integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/js/bootstrap.min.js" integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl" crossorigin="anonymous"></script>
    <script src="/js/main.js"></script>
  </body>
</html>
