<section class="jumbotron text-center">
  <div class="container">
    <h1 class="jumbotron-heading">My Garage</h1>
    <p class="lead text-muted"><%= currentUser.name %>'s cars and favorites</p>
    <a href="/garage/add" class="btn btn-primary">+ Add My Car</a>
    <% if (currentUser.isAdmin) { %>
      <a href="/garage/admin" class="btn btn-warning ml-2">Admin: Manage Images</a>
    <% } %>
  </div>
</section>

<div class="container pb-5">

  <h2 class="text-left mb-3">My Cars</h2>
  <% if (myCars.length === 0) { %>
    <p class="text-muted">You haven't added any cars yet. <a href="/garage/add">Add one now!</a></p>
  <% } else { %>
    <div class="row">
      <% myCars.forEach(car => { %>
        <div class="col-md-4 mb-4 card-col">
          <div class="card box-shadow">
            <span class="card-badge card-badge--garage">My Car</span>
            <a href="/cars/car?make=<%= encodeURIComponent(car.make) %>&model=<%= encodeURIComponent(car.model) %>&image=<%= encodeURIComponent(car.image) %>">
              <img class="card-img-top imgresp" src="<%= car.image %>" alt="<%= car.year %> <%= car.make %> <%= car.model %>">
            </a>
            <div class="card-body text-left">
              <h5 class="card-title"><%= car.year %> <%= car.make %> <%= car.model %></h5>
              <% if (car.notes) { %>
                <p class="card-text text-muted"><%= car.notes %></p>
              <% } %>
              <div class="d-flex" style="gap:0.5rem;">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#editCarModal<%= car.id %>">Edit</button>
                <form method="POST" action="/garage/car/<%= car.id %>?_method=DELETE" style="margin:0;">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                </form>
              </div>
            </div>
          </div>
        </div>

        <!-- Edit Modal -->
        <div class="modal fade" id="editCarModal<%= car.id %>" tabindex="-1" role="dialog" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title"><%= car.year %> <%= car.make %> <%= car.model %></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </div>
              <div class="modal-body">
                <div class="img-source-tabs">
                  <button type="button" class="img-tab-btn active" data-tab="car-url-<%= car.id %>">Use URL</button>
                  <button type="button" class="img-tab-btn" data-tab="car-upload-<%= car.id %>">Upload File</button>
                </div>

                <div id="car-url-<%= car.id %>" class="img-tab-pane">
                  <form id="car-url-form-<%= car.id %>" method="POST" action="/garage/car/<%= car.id %>?_method=PUT">
                    <input type="hidden" name="carid" value="<%= car.id %>">
                    <input type="text" class="form-control mb-2" name="imageUrl" placeholder="https://…" autocomplete="off">
                    <input type="text" class="form-control" name="notes" placeholder="Notes (optional)" value="<%= car.notes || '' %>">
                  </form>
                </div>

                <div id="car-upload-<%= car.id %>" class="img-tab-pane" style="display:none;">
                  <form id="car-upload-form-<%= car.id %>" method="POST" action="/garage/car/<%= car.id %>?_method=PUT" enctype="multipart/form-data">
                    <input type="hidden" name="carid" value="<%= car.id %>">
                    <input type="file" class="form-control-file mb-2" name="carImage" accept="image/*">
                    <input type="text" class="form-control" name="notes" placeholder="Notes (optional)" value="<%= car.notes || '' %>">
                  </form>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-primary garage-update-btn" data-id="<%= car.id %>">Save Changes</button>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <hr class="my-5">

  <h2 class="text-left mb-3">Favorite Cars</h2>
  <% if (favorites.length === 0) { %>
    <p class="text-muted">No favorites yet. <a href="/">Search for cars</a> to add some!</p>
  <% } else { %>
    <div class="row">
      <% favorites.forEach(f => { %>
        <div class="col-md-4 mb-4 card-col">
          <div class="card box-shadow">
            <span class="card-badge card-badge--favorite">&#9825; Favorite</span>
            <a href="/cars/car?make=<%= encodeURIComponent(f.make) %>&model=<%= encodeURIComponent(f.model) %>&image=<%= encodeURIComponent(f.image) %>">
              <img class="card-img-top imgresp" src="<%= f.image %>" alt="<%= f.make %> <%= f.model %>">
            </a>
            <div class="card-body text-left">
              <p class="card-text mb-2"><strong><%= f.make %> <%= f.model %></strong></p>
              <div class="d-flex" style="gap:0.5rem;">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#editFavModal<%= f.id %>">Edit</button>
                <form method="POST" action="/cars/favorites/delete/<%= f.id %>?_method=DELETE" style="margin:0;">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                </form>
              </div>
            </div>
          </div>
        </div>

        <!-- Edit Favorite Modal -->
        <div class="modal fade" id="editFavModal<%= f.id %>" tabindex="-1" role="dialog" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title"><%= f.make %> <%= f.model %></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </div>
              <div class="modal-body">
                <div class="img-source-tabs">
                  <button type="button" class="img-tab-btn active" data-tab="fav-url-<%= f.id %>">Use URL</button>
                  <button type="button" class="img-tab-btn" data-tab="fav-upload-<%= f.id %>">Upload File</button>
                </div>
                <div id="fav-url-<%= f.id %>" class="img-tab-pane">
                  <form id="fav-url-form-<%= f.id %>" method="POST" action="/cars/favorites/edit/<%= f.id %>?_method=PUT">
                    <input type="hidden" name="favid" value="<%= f.id %>">
                    <input type="text" class="form-control" name="newimagelink" placeholder="https://…" autocomplete="off">
                  </form>
                </div>
                <div id="fav-upload-<%= f.id %>" class="img-tab-pane" style="display:none;">
                  <form id="fav-upload-form-<%= f.id %>" method="POST" action="/cars/favorites/edit/<%= f.id %>?_method=PUT" enctype="multipart/form-data">
                    <input type="hidden" name="favid" value="<%= f.id %>">
                    <input type="file" class="form-control-file" name="newimage" accept="image/*">
                  </form>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-primary fav-update-btn" data-id="<%= f.id %>">Update Image</button>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>
