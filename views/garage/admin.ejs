<section class="jumbotron text-center">
  <div class="container">
    <h1 class="jumbotron-heading">Admin: Default Car Images</h1>
    <p class="lead text-muted">Cars still using placeholder images — update them below</p>
    <div class="d-inline-block mt-3 px-4 py-3 rounded" style="background:#1f1f1f;border:1px solid #333;">
      <div class="text-muted mb-1" style="font-size:0.78rem;letter-spacing:0.05em;text-transform:uppercase;">Unsplash Queue</div>
      <div style="font-size:1.6rem;font-weight:700;color:#f8fafc;">
        <%= unsplashRemaining.toLocaleString() %>
        <span style="font-size:1rem;font-weight:400;color:#71717a;">/ <%= totalCars.toLocaleString() %></span>
      </div>
      <div class="text-muted mt-1" style="font-size:0.78rem;">
        cars remaining &middot; ~<%= Math.ceil(unsplashRemaining / 50) %> runs at 50/hr
      </div>
    </div>
  </div>
</section>

<div class="container pb-5">

  <% if (unverifiedUsers && unverifiedUsers.length > 0) { %>
    <h2 class="mb-3">Unverified Users <span class="badge badge-warning"><%= unverifiedUsers.length %></span></h2>
    <div class="table-responsive mb-5">
      <table class="table table-dark table-sm">
        <thead><tr><th>Name</th><th>Email</th><th>Signed Up</th><th></th></tr></thead>
        <tbody>
          <% unverifiedUsers.forEach(u => { %>
            <tr>
              <td><%= u.name %></td>
              <td><%= u.email %></td>
              <td style="font-size:0.78rem;color:#71717a;"><%= new Date(u.createdAt).toLocaleDateString() %></td>
              <td>
                <form method="POST" action="/garage/admin/verify-user/<%= u.id %>" style="margin:0;">
                  <button type="submit" class="btn btn-sm btn-outline-success">Verify</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <hr class="mb-5">
  <% } %>

  <% if (proposals && proposals.length > 0) { %>
    <h2 class="mb-3">Pending Image Proposals <span class="badge badge-danger"><%= proposals.length %></span></h2>
    <div class="row mb-5">
      <% proposals.forEach(p => { %>
        <div class="col-md-4 mb-4">
          <div class="card box-shadow">
            <img class="card-img-top imgresp" src="<%= p.imageUrl %>" alt="Proposed image" onerror="this.src='https://i.ibb.co/PwkqdSy/placeholder.png'">
            <div class="card-body text-left">
              <h6 class="card-title mb-1"><%= p.car.make %> <%= p.car.model %></h6>
              <p class="text-muted mb-2" style="font-size:0.75rem;">By <%= p.user.name %> &middot; <%= new Date(p.createdAt).toLocaleDateString() %></p>
              <div class="d-flex" style="gap:0.5rem;">
                <form method="POST" action="/garage/admin/proposal/<%= p.id %>/approve" style="margin:0;">
                  <button type="submit" class="btn btn-sm btn-primary">Approve</button>
                </form>
                <form method="POST" action="/garage/admin/proposal/<%= p.id %>/reject" style="margin:0;">
                  <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <hr class="mb-5">
  <% } %>

  <!-- All Users -->
  <h2 class="mb-3">All Users <span class="badge badge-secondary"><%= allUsers.length %></span></h2>
  <div class="table-responsive mb-5">
    <table class="table table-dark table-sm table-hover">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Joined</th>
          <th>Last Login</th>
          <th>Favorites</th>
          <th>Garage</th>
          <th>Proposals</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% allUsers.forEach(u => { %>
          <tr>
            <td><%= u.name %><% if (u.isAdmin) { %> <span class="badge badge-warning">Admin</span><% } %></td>
            <td style="font-size:0.78rem;"><%= u.email %></td>
            <td style="font-size:0.78rem;color:#71717a;"><%= new Date(u.createdAt).toLocaleDateString() %></td>
            <td style="font-size:0.78rem;color:#71717a;"><%= u.lastLoginAt ? new Date(u.lastLoginAt).toLocaleDateString() : '—' %></td>
            <td><%= u.favorites %></td>
            <td><%= u.garageCars %></td>
            <td><%= u.proposals %></td>
            <td>
              <% if (u.emailVerified) { %>
                <span style="color:#4ade80;font-size:0.72rem;">Verified</span>
              <% } else { %>
                <span style="color:#f87171;font-size:0.72rem;">Unverified</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <hr class="mb-5">

  <% if (cars.length === 0) { %>
    <div class="alert alert-success">All cars have custom images. Nothing to update!</div>
  <% } else { %>
    <p class="text-muted mb-4">Showing up to 100 cars with placeholder images.</p>
    <div class="row">
      <% cars.forEach(car => { %>
        <div class="col-md-4 mb-4">
          <div class="card box-shadow">
            <img class="card-img-top imgresp" src="<%= car.image %>" alt="<%= car.make %> <%= car.model %>">
            <div class="card-body text-left">
              <h6 class="card-title"><%= car.make %> <%= car.model %></h6>
              <button class="btn btn-sm btn-outline-primary btn-block" data-toggle="modal" data-target="#adminModal<%= car.id %>">
                Update Image
              </button>
            </div>
          </div>
        </div>

        <!-- Modal -->
        <div class="modal fade" id="adminModal<%= car.id %>" tabindex="-1" role="dialog" aria-hidden="true">
          <div class="modal-dialog" role="document">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Update image for <%= car.make %> <%= car.model %></h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </div>
              <div class="modal-body">
                <form method="POST" action="/garage/admin/car/<%= car.id %>?_method=PUT" enctype="multipart/form-data">
                  <div class="form-group">
                    <label>Image URL</label>
                    <input type="url" class="form-control" name="imageUrl" placeholder="https://...">
                  </div>
                  <div class="text-center text-muted mb-2">— or —</div>
                  <div class="form-group">
                    <label>Upload File</label>
                    <input type="file" class="form-control-file" name="carImage" accept="image/jpeg,image/png,image/webp">
                  </div>
                  <button type="submit" class="btn btn-primary btn-block">Save Image</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
