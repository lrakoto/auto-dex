<!-- Hero Image -->
<div class="car-hero" style="background-image: url('<%= image %>');">
  <div class="car-hero-overlay">
    <div class="car-hero-text">
      <h1><%= make %> <span><%= model %></span></h1>
      <% if (country) { %>
        <p class="car-hero-sub"><%= country %></p>
      <% } %>
    </div>
  </div>
</div>

<!-- Actions Bar -->
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap">
    <a href="/cars?selectmake=<%= encodeURIComponent(make) %>" class="btn btn-outline-secondary btn-sm">&larr; Back to <%= make %></a>
    <div class="d-flex align-items-center">
      <span class="text-muted mr-3">&#9825; <%= favcount %> favorites</span>
      <% if (currentUser) { %>
        <form action="/cars/fav" method="POST" class="d-inline">
          <input type="hidden" name="favecar_model" value="<%= model %>"/>
          <input type="hidden" name="favecar_make" value="<%= make %>"/>
          <input type="hidden" name="favecar_image" value="<%= image %>"/>
          <input type="hidden" name="userId" value="<%= currentUser.id %>"/>
          <button type="submit" class="btn btn-primary btn-sm">+ Add to Favorites</button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="btn btn-primary btn-sm">Login to Favorite</a>
      <% } %>
    </div>
  </div>
</div>

<div class="container pb-5">
  <div class="row text-left">

    <!-- About -->
    <div class="col-lg-8">
      <h2 class="mb-3"><%= make %> <%= model %></h2>

      <% if (wikiSummary) { %>
        <p class="lead"><%= wikiSummary %></p>
        <% if (wikiUrl) { %>
          <a href="<%= wikiUrl %>" target="_blank" rel="noopener" class="text-muted small">Read more on Wikipedia &rarr;</a>
        <% } %>
      <% } else { %>
        <p class="text-muted">No description available for this model.</p>
      <% } %>
    </div>

    <!-- Media Links -->
    <div class="col-lg-4 mt-4 mt-lg-0">
      <div class="card border-0 bg-light p-3">
        <h5 class="mb-3">Watch &amp; Read</h5>
        <p class="text-muted small mb-3">Find <strong><%= make %> <%= model %></strong> content from top automotive channels:</p>
        <div class="list-group list-group-flush">
          <% mediaLinks.forEach(link => { %>
            <a href="<%= link.url %>" target="_blank" rel="noopener"
               class="list-group-item list-group-item-action d-flex align-items-center px-0 py-2 border-0 bg-transparent">
              <span class="mr-2" style="font-size:1.2rem;"><%= link.icon %></span>
              <span><%= link.label %></span>
              <span class="ml-auto text-muted small">YouTube &rarr;</span>
            </a>
          <% }) %>
        </div>
      </div>
    </div>

  </div>

  <!-- Related Models -->
  <% if (relatedCars.length > 0) { %>
    <hr class="my-5">
    <h4 class="mb-3 text-left">More from <%= make %></h4>
    <div class="row">
      <% relatedCars.forEach(c => { %>
        <div class="col-md-4 col-6 mb-4">
          <div class="card box-shadow h-100">
            <a href="/cars/car?make=<%= encodeURIComponent(c.make) %>&model=<%= encodeURIComponent(c.model) %>">
              <img class="card-img-top imgresp" src="<%= c.image %>" alt="<%= c.model %>">
            </a>
            <div class="card-body py-2 px-3">
              <p class="card-text mb-0">
                <a href="/cars/car?make=<%= encodeURIComponent(c.make) %>&model=<%= encodeURIComponent(c.model) %>" class="text-dark">
                  <small><%= c.model %></small>
                </a>
              </p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<style>
  .car-hero {
    width: 100%;
    height: 460px;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .car-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.15) 55%, transparent 100%);
    display: flex;
    align-items: flex-end;
  }
  .car-hero-text {
    padding: 2rem;
    text-align: left;
    color: #fff;
  }
  .car-hero-text h1 {
    font-size: 2.8rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }
  .car-hero-text h1 span {
    font-weight: 300;
  }
  .car-hero-sub {
    font-size: 0.85rem;
    opacity: 0.75;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }
</style>
