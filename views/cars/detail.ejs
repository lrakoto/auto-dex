<!-- Hero Image -->
<div class="car-hero" style="background-image: url('<%= image %>');">
  <div class="car-hero-overlay">
    <div class="car-hero-text">
      <h1><%= make %> <span><%= model %></span></h1>
      <% if (country) { %>
        <p class="car-hero-sub"><%= country %></p>
      <% } %>
    </div>
  </div>
</div>

<!-- Actions Bar -->
<div class="detail-container">
  <div class="detail-actions d-flex justify-content-between align-items-center flex-wrap" style="gap:1rem;">
    <a href="/cars?selectmake=<%= encodeURIComponent(make) %>" class="btn btn-outline-secondary btn-sm">&larr; <%= make %></a>
    <div class="d-flex align-items-center" style="gap:1rem;">
      <span class="text-muted" style="font-size:0.8rem;">&#9825; <%= favcount %></span>
      <% if (currentUser) { %>
        <form action="/cars/fav" method="POST" class="d-inline">
          <input type="hidden" name="favecar_model" value="<%= model %>"/>
          <input type="hidden" name="favecar_make" value="<%= make %>"/>
          <input type="hidden" name="favecar_image" value="<%= image %>"/>
          <input type="hidden" name="userId" value="<%= currentUser.id %>"/>
          <button type="submit" class="btn btn-primary btn-sm">+ Favorite</button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="btn btn-primary btn-sm">Log in to Favorite</a>
      <% } %>
    </div>
  </div>
</div>

<div class="detail-container py-5 detail-section">
  <div class="row">

    <!-- About -->
    <div class="col-lg-8 mb-5 mb-lg-0">
      <div class="accent-line"></div>
      <h2 class="mb-4" style="font-size:1.75rem;"><%= make %> <span style="font-weight:300;"><%= model %></span></h2>
      <% if (wikiSummary) { %>
        <p class="lead" style="color:#a1a1aa;line-height:1.75;"><%= wikiSummary %></p>
        <% if (wikiUrl) { %>
          <a href="<%= wikiUrl %>" target="_blank" rel="noopener" style="font-size:0.78rem;letter-spacing:0.06em;text-transform:uppercase;color:#52525b;">
            Wikipedia &rarr;
          </a>
        <% } %>
      <% } else { %>
        <p class="text-muted">No description available for this model.</p>
      <% } %>
      <% if (typeof carSpecs !== 'undefined' && carSpecs) { %>
        <div class="specs-grid" style="margin-top:2rem;">
          <div class="accent-line"></div>
          <h5 style="font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-subtle);margin:1rem 0 1rem;">Specs — <%= carSpecs.year %></h5>
          <div class="specs-row">
            <% if (carSpecs.type) { %><div class="spec-item"><span class="spec-label">Class</span><span class="spec-value"><%= carSpecs.type %></span></div><% } %>
            <% if (carSpecs.displacement) { %><div class="spec-item"><span class="spec-label">Engine</span><span class="spec-value"><%= carSpecs.displacement %>L<% if (carSpecs.cylinders) { %> &middot; <%= carSpecs.cylinders %>-cyl<% } %></span></div><% } %>
            <% if (carSpecs.transmission) { %><div class="spec-item"><span class="spec-label">Transmission</span><span class="spec-value"><%= carSpecs.transmission %></span></div><% } %>
            <% if (carSpecs.drive) { %><div class="spec-item"><span class="spec-label">Drive</span><span class="spec-value"><%= carSpecs.drive %></span></div><% } %>
            <% if (carSpecs.fuel) { %><div class="spec-item"><span class="spec-label">Fuel</span><span class="spec-value"><%= carSpecs.fuel %></span></div><% } %>
            <% if (carSpecs.cityMpg && carSpecs.hwyMpg) { %><div class="spec-item"><span class="spec-label">MPG</span><span class="spec-value"><%= carSpecs.cityMpg %> city &middot; <%= carSpecs.hwyMpg %> hwy</span></div><% } %>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Media Links -->
    <div class="col-lg-4">
      <div class="media-card">
        <h5>Watch &amp; Read</h5>
        <% mediaLinks.forEach(link => { %>
          <a href="<%= link.url %>" target="_blank" rel="noopener"
             class="d-flex align-items-center py-2"
             style="border-bottom:1px solid #27272a;color:#a1a1aa;font-size:0.85rem;gap:0.6rem;">
            <span><%= link.icon %></span>
            <span><%= link.label %></span>
            <span class="ml-auto" style="font-size:0.72rem;color:#3f3f46;">↗</span>
          </a>
        <% }) %>
      </div>
    </div>

  </div>

  <!-- Related Models -->
  <% if (relatedCars.length > 0) { %>
    <div style="margin-top:4rem;">
      <p class="eyebrow" style="margin-bottom:1.25rem;">More from <%= make %></p>
      <div class="row related-row">
        <% relatedCars.forEach(c => { %>
          <div class="col-md-4 col-6 mb-4 card-col">
            <div class="card h-100">
              <a href="/cars/car?make=<%= encodeURIComponent(c.make) %>&model=<%= encodeURIComponent(c.model) %>">
                <img class="card-img-top imgresp" src="<%= c.image %>" alt="<%= c.model %>">
              </a>
              <div class="card-body">
                <p class="card-text mb-0">
                  <a href="/cars/car?make=<%= encodeURIComponent(c.make) %>&model=<%= encodeURIComponent(c.model) %>" class="text-dark card-cover"><%= c.model %></a>
                </p>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<style>
  .car-hero {
    width: 100%;
    height: 480px;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .car-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(3,6,14,0.97) 0%, rgba(3,6,14,0.3) 55%, transparent 100%);
    display: flex;
    align-items: flex-end;
  }
  .car-hero-text {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    text-align: left;
    color: #fff;
  }
  .car-hero-text h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 0.35rem;
    text-shadow: none;
  }
  .car-hero-text h1 span { font-weight: 300; }
  .car-hero-sub {
    font-size: 0.72rem;
    color: rgba(250,250,250,0.5);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .detail-container { max-width: 1200px; width: 100%; margin: 0 auto; padding: 0 2rem; }
  .detail-actions { padding: 1.5rem 0; border-bottom: 1px solid #27272a; }
  .media-card { background: url('/assets/noise.svg') repeat, rgba(10,16,30,0.52); backdrop-filter: blur(14px) saturate(160%); -webkit-backdrop-filter: blur(14px) saturate(160%); border: 1px solid rgba(255,255,255,0.07); box-shadow: inset 0 1px 0 rgba(255,255,255,0.09), 0 4px 20px rgba(0,0,0,0.35); border-radius: 3px; padding: 1.5rem; }
  .media-card h5 { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #71717a; margin-bottom: 1rem; }
</style>

<script>
(function() {
  try {
    var key = 'autodex_recent';
    var entry = { make: '<%= make.replace(/'/g, "\\'") %>', model: '<%= model.replace(/'/g, "\\'") %>', image: '<%= image.replace(/'/g, "\\'") %>', url: window.location.href };
    var list = JSON.parse(localStorage.getItem(key) || '[]');
    list = list.filter(function(c) { return !(c.make === entry.make && c.model === entry.model); });
    list.unshift(entry);
    if (list.length > 6) list = list.slice(0, 6);
    localStorage.setItem(key, JSON.stringify(list));
  } catch(e) {}
})();
</script>
