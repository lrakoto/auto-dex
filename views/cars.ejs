<section class="jumbotron text-center">
    <div class="container">
      <h1 class="jumbotron-heading">Search Results for <%= search %></h1>
      <form action="/search" method="GET" class="d-flex justify-content-center align-items-end mt-4" style="gap:0.75rem;flex-wrap:wrap;max-width:480px;margin:1.5rem auto 0;">
        <div class="search-input-wrap" style="flex:1;min-width:200px;text-align:left;">
          <label for="q" style="font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-subtle);margin-bottom:0.35rem;display:block;">Make or Model</label>
          <input type="text" class="form-control form-control-lg" name="q" id="q" value="<%= search %>" placeholder="e.g. Toyota, Camry…" autocomplete="off">
          <div class="suggest-dropdown"></div>
        </div>
        <button class="btn btn-primary btn-lg" type="submit" style="padding:0.65rem 1.5rem;white-space:nowrap;">Search &rarr;</button>
      </form>
    </div>
  </section>


<div class="album py-5 bg-light">
  <div class="container" id="cars-grid">
    <%- include('partials/car-grid') %>
  </div>
</div>