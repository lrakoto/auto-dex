<style>
  body {
    background: url(https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=1920&q=80) center center / cover no-repeat fixed;
  }
  .home-overlay {
    background: linear-gradient(to right, rgba(3,6,14,0.24) 40%, rgba(3,6,14,0.10) 100%);
    min-height: calc(100vh - 56px);
    display: flex;
    flex-direction: column;
  }
  .home-inner {
    flex: 1;
    display: flex;
    align-items: center;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
  }
  #recently-viewed {
    padding: 1.25rem 2rem 1.75rem;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
